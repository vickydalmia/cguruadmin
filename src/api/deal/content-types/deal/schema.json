{
  "kind": "collectionType",
  "collectionName": "deals",
  "info": {
    "singularName": "deal",
    "pluralName": "deals",
    "displayName": "Deal",
    "description": "Product deals with pricing, images, and affiliate links"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "excerpt": {
      "type": "text"
    },
    "dealImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "salePrice": {
      "type": "decimal"
    },
    "mrp": {
      "type": "decimal"
    },
    "discount": {
      "type": "string"
    },
    "isPopular": {
      "type": "boolean",
      "default": false
    },
    "offerType": {
      "type": "enumeration",
      "enum": ["fashion", "travel", "electronics", "food", "exclusive", "newly_added"]
    },
    "affiliateLink": {
      "type": "string"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store",
      "inversedBy": "deals"
    },
    "bank": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::bank.bank",
      "inversedBy": "deals"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "deals"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "deals"
    },
    "displayStore": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "deals"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
