{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon",
    "description": "Coupon codes (static and unique) for stores, banks, categories, and brands"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "excerpt": {
      "type": "text"
    },
    "code": {
      "type": "string"
    },
    "couponType": {
      "type": "enumeration",
      "enum": ["static", "unique"],
      "default": "static",
      "required": true
    },
    "uniqueCouponPool": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::unique-coupon-pool.unique-coupon-pool",
      "inversedBy": "coupons"
    },
    "isPopular": {
      "type": "boolean",
      "default": false
    },
    "offerType": {
      "type": "enumeration",
      "enum": ["fashion", "travel", "electronics", "food", "exclusive", "newly_added"]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "affiliateLink": {
      "type": "string"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::store.store",
      "inversedBy": "coupons"
    },
    "bank": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::bank.bank",
      "inversedBy": "coupons"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "coupons"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "coupons"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "coupons"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
